# Copy to secrets.toml in this folder for local Streamlit runs:
#   FYP_FINAL/.streamlit/secrets.toml
# Or use FYP_FINAL/.env (recommended) — see .env.example
#
# Do NOT commit secrets.toml with real keys.

OPENAI_API_KEY = ""

# PostgreSQL (Neon / Supabase / Railway) — persistent sessions + chat memory
# DATABASE_URL = "postgresql://user:pass@host:5432/dbname"

GMAIL_EMAIL = ""
GMAIL_APP_PASSWORD = ""

TWILIO_ACCOUNT_SID = ""
TWILIO_AUTH_TOKEN = ""
TWILIO_WHATSAPP_FROM = ""
TWILIO_WHATSAPP_TO = ""
TWILIO_CONTENT_SID = ""

# Google Drive (Streamlit Cloud — paste JSON as one line or use TOML multiline string)
# GOOGLE_TOKEN_JSON = '{"token": "...", "refresh_token": "...", ...}'
# GOOGLE_SERVICE_ACCOUNT_JSON = '{"type": "service_account", ...}'
# GOOGLE_CREDENTIALS_JSON = '{"installed": {...}}'  # OAuth client; still needs token on cloud

# Optional for hosted deploy
# FYP_HOSTED = true
