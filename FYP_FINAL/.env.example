# Copy this file to `.env` in the same folder as `config.py` and fill in secrets.
# `.env` is gitignored — never commit real keys.

# Required for LLM features (orchestrator, HR, finance, IT, documents, recruitment)
OPENAI_API_KEY=

# Gmail (IMAP send/read — spaces in app passwords are stripped automatically)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# Twilio WhatsApp (optional — leave empty to skip WhatsApp features)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_WHATSAPP_TO=
TWILIO_CONTENT_SID=

# Optional: Google OAuth JSON path relative to project root (default: credentials.json)
# GOOGLE_CREDENTIALS_FILE=credentials.json
# GOOGLE_TOKEN_FILE=token.json

# Optional: MCP server bind (defaults shown)
# MCP_SERVER_HOST=localhost
# MCP_SERVER_PORT=8765

# Optional: override demo UI passwords (defaults: admin123, hr123, …)
# FYP_PASSWORD_ADMIN=
# FYP_PASSWORD_HR=
# FYP_PASSWORD_FINANCE=
# FYP_PASSWORD_IT=
# FYP_PASSWORD_DEMO=
# FYP_PASSWORD_ASSISTANT=

# Optional: DEMO_MODE=true

# When deploying on Streamlit Community Cloud, add the same keys in the dashboard **Secrets**
# and set this so the app skips the in-process MCP HTTP bind (recommended on hosted tiers):
# FYP_HOSTED=true
